local SUPREME_URLS = {
    "https://supremevalues.com/mm2/ancients",
    "https://supremevalues.com/mm2/chromas",
    "https://supremevalues.com/mm2/godlies",
}

local function HTML_DECODE(TEXT)
    if not TEXT then
        return ""
    end

    TEXT = TEXT:gsub("&#039;", "'")
    TEXT = TEXT:gsub("&quot;", '"')
    TEXT = TEXT:gsub("&amp;", "&")
    TEXT = TEXT:gsub("&lt;", "<")
    TEXT = TEXT:gsub("&gt;", ">")
    TEXT = TEXT:gsub("&nbsp;", " ")
    return TEXT
end

local function NORMALIZE_DISPLAY_NAME(NAME)
    NAME = HTML_DECODE(NAME)
    NAME = NAME:gsub("<.->", "")
    NAME = NAME:gsub("^%s+", "")
    NAME = NAME:gsub("%s+$", "")
    NAME = NAME:gsub("%s+", " ")

    NAME = NAME:gsub("^C%.%s*", "Chroma ")

    NAME = NAME:gsub("^Travelers ", "Traveler's ")
    NAME = NAME:gsub("^Vampires ", "Vampire's ")
    NAME = NAME:gsub("^Winters ", "Winter's ")
    NAME = NAME:gsub("^Hallows ", "Hallow's ")

    return NAME
end

local function NORMALIZE_LOOKUP_NAME(NAME)
    return string.lower(NORMALIZE_DISPLAY_NAME(NAME))
end

local ITEM_VALUES = {}

local function REBUILD_FALLBACK_VALUES()
    ITEM_VALUES = {}

    for NAME, VALUE in pairs(ancientValues) do
        ITEM_VALUES[NORMALIZE_LOOKUP_NAME(NAME)] = VALUE
    end
end

local function PARSE_PAGE_VALUES(HTML)
    local COUNT = 0

    for RAW_VALUE, RAW_NAME in HTML:gmatch('data%-value="([%d,]+)".-data%-name=\'(.-)\'') do
        local VALUE = tonumber((RAW_VALUE:gsub(",", "")))
        local NAME = NORMALIZE_DISPLAY_NAME(RAW_NAME)

        if VALUE and NAME ~= "" then
            ITEM_VALUES[NORMALIZE_LOOKUP_NAME(NAME)] = VALUE
            COUNT = COUNT + 1
        end
    end

    return COUNT
end

local function REFRESH_VALUES_FROM_SUPREME()
    REBUILD_FALLBACK_VALUES()

    local TOTAL_PARSED = 0

    for _, URL in ipairs(SUPREME_URLS) do
        local OK, HTML = pcall(function()
            return game:HttpGet(URL)
        end)

        if OK and HTML and HTML ~= "" then
            TOTAL_PARSED = TOTAL_PARSED + PARSE_PAGE_VALUES(HTML)
        end
    end

    return TOTAL_PARSED
end

local function GET_ITEM_VALUE(ITEM_NAME, IS_CHROMA)
    local LOOKUP_NAME = ITEM_NAME

    if IS_CHROMA and not ITEM_NAME:match("^Chroma%s+") and not ITEM_NAME:match("^C%.%s*") then
        LOOKUP_NAME = "Chroma " .. ITEM_NAME
    end

    return ITEM_VALUES[NORMALIZE_LOOKUP_NAME(LOOKUP_NAME)]
end

-- Функция получения стабильности предмета
local function GET_ITEM_STABILITY(ITEM_NAME, IS_CHROMA)
    local LOOKUP_NAME = ITEM_NAME

    if IS_CHROMA and not ITEM_NAME:match("^Chroma%s+") and not ITEM_NAME:match("^C%.%s*") then
        LOOKUP_NAME = "Chroma " .. ITEM_NAME
    end

    return STABILITY_LOOKUP[NORMALIZE_LOOKUP_NAME(LOOKUP_NAME)]
end

-- Извлечение статуса из строки стабильности (например "Underpaid" из "Underpaid, 220")
local function GET_STATUS_FROM_STRING(FULL_STRING)
    if not FULL_STRING then return nil end
    local status = string.match(FULL_STRING, "^(%w+)")
    return status
end

-- Получение цвета по строке стабильности
local function GET_STABILITY_COLOR(FULL_STRING)
    local status = GET_STATUS_FROM_STRING(FULL_STRING)
    if status and stabilityColors[status] then
        return stabilityColors[status]
    end
    return stabilityColors["Unknown"]
end

