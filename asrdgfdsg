-- ==============================
-- НОРМАЛИЗАЦИЯ ИМЁН
-- ==============================
local function NORMALIZE_DISPLAY_NAME(NAME)
    NAME = NAME:gsub("<.->", "")
    NAME = NAME:gsub("^%s+", "")
    NAME = NAME:gsub("%s+$", "")
    NAME = NAME:gsub("%s+", " ")
    NAME = NAME:gsub("^C%.%s*", "Chroma ")
    NAME = NAME:gsub("^Travelers ", "Traveler's ")
    NAME = NAME:gsub("^Vampires ", "Vampire's ")
    NAME = NAME:gsub("^Winters ", "Winter's ")
    NAME = NAME:gsub("^Hallows ", "Hallow's ")
    return NAME
end

local function NORMALIZE_LOOKUP_NAME(NAME)
    return string.lower(NORMALIZE_DISPLAY_NAME(NAME))
end

-- ==============================
-- ПАРСИНГ ЧИСЕЛ / ДИАПАЗОНОВ
-- ==============================
local function PARSE_NUMBER(TEXT)
    if type(TEXT) == "number" then return TEXT end
    if type(TEXT) ~= "string" then return nil end
    TEXT = TEXT:gsub(",", ""):gsub("%s+", "")
    return tonumber(TEXT)
end

-- "3,450 - 3,500" -> 3450, 3500
local function PARSE_RANGE(TEXT)
    if type(TEXT) ~= "string" then return nil, nil end
    local CLEAN = TEXT:gsub(",", "")
    local A, B = CLEAN:match("(%d+%.?%d*)%s*%-%s*(%d+%.?%d*)")
    if A and B then
        A, B = tonumber(A), tonumber(B)
        if A and B then
            if A > B then A, B = B, A end
            return A, B
        end
    end
    return nil, nil
end

-- "x4 T1 Legendaries" -> 4, 1, "legendaries"
local function PARSE_MULTIPLIER_VALUE(TEXT)
    if type(TEXT) ~= "string" then return nil end
    local MULT, TIER, CAT_WORD = TEXT:match("^[xX](%d+)%s+[tT](%d+)%s+(%a+)")
    if not MULT then return nil end
    local CAT = string.lower(CAT_WORD)
    -- "Legendaries" -> "legendaries", "Rares" -> "rares" и т.д.
    if not TAG_TO_CATEGORY[CAT] then
        -- уже во множественном числе — проверяем по списку категорий
        local FOUND = false
        for _, C in ipairs(CATEGORIES) do
            if C == CAT then FOUND = true break end
        end
        if not FOUND then return nil end
    else
        CAT = TAG_TO_CATEGORY[CAT]
    end
    return tonumber(MULT), tonumber(TIER), CAT
end

-- ==============================
-- ДАННЫЕ
-- ==============================
-- ITEM_DB[lookupName][category] = entry
-- entry = { valueText, valueNum, minV, maxV, demand, status, range, rise }
local ITEM_DB = {}
-- VARIANT_DB[baseName][category] = { {suffix="Gun", entry=...}, ... }
local VARIANT_DB = {}
-- TIER_STATS[category][tierNum] = { min = X, max = Y } (только числовые валюты)
local TIER_STATS = {}
local DATA_LOADED = false
local LOADED_CATEGORIES = 0
local PARSED_COUNT = 0

local function TRANSLATE_STABILITY_STATUS(STATUS)
    if not STATUS or STATUS == "" or STATUS == "N/A" then return nil end
    STATUS = STATUS:gsub("^%s+", ""):gsub("%s+$", "")
    if STATUS == "" then return nil end
    return STABILITY_STATUS_MAP[STATUS] or STATUS
end

local function RECORD_TIER_STAT(CATEGORY, TIER_TEXT, VALUE_NUM)
    if not VALUE_NUM or type(TIER_TEXT) ~= "string" then return end
    local TIER_NUM = tonumber(TIER_TEXT:match("[tT]ier%s+(%d+)"))
    if not TIER_NUM then return end
    TIER_STATS[CATEGORY] = TIER_STATS[CATEGORY] or {}
    local STAT = TIER_STATS[CATEGORY][TIER_NUM]
    if not STAT then
        TIER_STATS[CATEGORY][TIER_NUM] = { min = VALUE_NUM, max = VALUE_NUM }
    else
        if VALUE_NUM < STAT.min then STAT.min = VALUE_NUM end
        if VALUE_NUM > STAT.max then STAT.max = VALUE_NUM end
    end
end

local function FETCH_FROM(BASE_URL, CATEGORY)
    local OK, RESPONSE = pcall(function()
        return game:HttpGet(BASE_URL .. CATEGORY)
    end)
    if not OK or not RESPONSE or RESPONSE == "" then return nil end
    local PARSED_OK, DATA = pcall(function()
        return HttpService:JSONDecode(RESPONSE)
    end)
    if not PARSED_OK or type(DATA) ~= "table" or type(DATA.items) ~= "table" then
        return nil
    end
    return DATA.items
end

local function FETCH_CATEGORY(CATEGORY)
    for _, BASE_URL in ipairs(BASE_API_URLS) do
        local ITEMS = FETCH_FROM(BASE_URL, CATEGORY)
        if ITEMS then return ITEMS end
    end
    return nil
end

local function REFRESH_VALUES_FROM_SITE()
    ITEM_DB = {}
    VARIANT_DB = {}
    TIER_STATS = {}
    LOADED_CATEGORIES = 0
    PARSED_COUNT = 0

    for _, CATEGORY in ipairs(CATEGORIES) do
        local ITEMS = FETCH_CATEGORY(CATEGORY)
        if not ITEMS then
            task.wait(1)
            ITEMS = FETCH_CATEGORY(CATEGORY) -- одна повторная попытка
        end
        if ITEMS then
            LOADED_CATEGORIES = LOADED_CATEGORIES + 1
            for _, ITEM in ipairs(ITEMS) do
                if type(ITEM) == "table" and type(ITEM.name) == "string" and ITEM.name ~= "" then
                    local LOOKUP = NORMALIZE_LOOKUP_NAME(ITEM.name)
                    local VALUE_TEXT = ITEM.value
                    local VALUE_NUM = PARSE_NUMBER(VALUE_TEXT)
                    local RANGE_MIN, RANGE_MAX = PARSE_RANGE(ITEM.rangedValue)

                    RECORD_TIER_STAT(CATEGORY, ITEM.tier, VALUE_NUM)

                    local ENTRY = {
                        valueText = (type(VALUE_TEXT) == "string" and VALUE_TEXT ~= "") and VALUE_TEXT or nil,
                        valueNum = VALUE_NUM,
                        rangeMin = RANGE_MIN,
                        rangeMax = RANGE_MAX,
                        rangeText = (ITEM.rangedValue and ITEM.rangedValue ~= "N/A" and ITEM.rangedValue ~= "") and ITEM.rangedValue or nil,
                        demand = PARSE_NUMBER(ITEM.demand),
                        rise = PARSE_NUMBER(ITEM.riseChance),
                        status = TRANSLATE_STABILITY_STATUS(ITEM.stability),
                        category = CATEGORY,
                    }

                    ITEM_DB[LOOKUP] = ITEM_DB[LOOKUP] or {}
                    -- не перезаписываем, если имя внутри категории повторяется
                    if not ITEM_DB[LOOKUP][CATEGORY] then
                        ITEM_DB[LOOKUP][CATEGORY] = ENTRY
                        PARSED_COUNT = PARSED_COUNT + 1
                    end

                    -- Индекс вариантов: "arctic (gun)" -> base "arctic", suffix "Gun"
                    local BASE, SUFFIX = LOOKUP:match("^(.-)%s*%((%a+)%)$")
                    if BASE and SUFFIX and (SUFFIX == "gun" or SUFFIX == "knife") then
                        VARIANT_DB[BASE] = VARIANT_DB[BASE] or {}
                        VARIANT_DB[BASE][CATEGORY] = VARIANT_DB[BASE][CATEGORY] or {}
                        table.insert(VARIANT_DB[BASE][CATEGORY], {
                            suffix = (SUFFIX == "gun") and "Gun" or "Knife",
                            entry = ENTRY,
                        })
                    end
                end
            end
        end
    end

    DATA_LOADED = PARSED_COUNT > 0
    return PARSED_COUNT
end

-- ==============================
-- РАСЧЁТ МИН/МАКС ВАЛЮТЫ ЗАПИСИ
-- ==============================
-- Возвращает: displayText, minV, maxV, nominalV (может быть nil если N/A)
local function RESOLVE_ENTRY_VALUE(ENTRY)
    -- 1) Обычная числовая валюта
    if ENTRY.valueNum then
        local MIN_V, MAX_V = ENTRY.valueNum, ENTRY.valueNum
        -- Диапазон (Underpaid For / Overpaid For / Fluctuating и т.д.)
        if ENTRY.rangeMin and ENTRY.rangeMax then
            MIN_V = math.min(MIN_V, ENTRY.rangeMin)
            MAX_V = math.max(MAX_V, ENTRY.rangeMax)
        end
        return tostring(ENTRY.valueNum), MIN_V, MAX_V, ENTRY.valueNum
    end

    -- 2) Валюта вида "x4 T1 Legendaries"
    if ENTRY.valueText then
        local MULT, TIER, CAT = PARSE_MULTIPLIER_VALUE(ENTRY.valueText)
        if MULT and TIER and CAT and TIER_STATS[CAT] and TIER_STATS[CAT][TIER] then
            local STAT = TIER_STATS[CAT][TIER]
            local MIN_V = MULT * STAT.min
            local MAX_V = MULT * STAT.max
            local NOMINAL = math.floor((MIN_V + MAX_V) / 2 + 0.5)
            local DISPLAY = ENTRY.valueText
            if MIN_V ~= MAX_V then
                DISPLAY = DISPLAY .. " (~" .. MIN_V .. "-" .. MAX_V .. ")"
            else
                DISPLAY = DISPLAY .. " (~" .. MIN_V .. ")"
            end
            return DISPLAY, MIN_V, MAX_V, NOMINAL
        end
        -- Просто текст (например "N/A") — валюты нет
        return ENTRY.valueText, 0, 0, nil
    end

    return "N/A", 0, 0, nil
end

-- ==============================
-- ПОИСК ПРЕДМЕТА (с учётом категории и вариантов Gun/Knife)
-- ==============================
local function GET_LOOKUP_NAME(ITEM_NAME, IS_CHROMA)
    local LOOKUP_NAME = ITEM_NAME
    if IS_CHROMA and not ITEM_NAME:match("^Chroma%s+") and not ITEM_NAME:match("^C%.%s*") then
        LOOKUP_NAME = "Chroma " .. ITEM_NAME
    end
    return NORMALIZE_LOOKUP_NAME(LOOKUP_NAME)
end

-- Возвращает список записей { {suffix=nil|"Gun"|"Knife", entry=...}, ... }
-- Приоритет: сперва категория из тега GUI, затем ЕДИНЫЙ проход по
-- приоритету категорий, где точное имя и варианты Gun/Knife проверяются
-- на КАЖДОМ шаге. Это чинит случаи вроде Arctic: "Arctic (Gun/Knife)" в
-- legendaries теперь выигрывает у пустого "Arctic" (N/A) в untradables.
local function FIND_ITEM_ENTRIES(ITEM_NAME, IS_CHROMA, PREFERRED_CATEGORY)
    local LOOKUP = GET_LOOKUP_NAME(ITEM_NAME, IS_CHROMA)
    local BY_CATEGORY = ITEM_DB[LOOKUP]
    local VARIANTS = VARIANT_DB[LOOKUP]
    if not BY_CATEGORY and not VARIANTS then return nil end

    -- 1) Категория из тега редкости в GUI — самый надёжный признак
    if PREFERRED_CATEGORY then
        if BY_CATEGORY and BY_CATEGORY[PREFERRED_CATEGORY] then
            return { { suffix = nil, entry = BY_CATEGORY[PREFERRED_CATEGORY] } }
        end
        if VARIANTS and VARIANTS[PREFERRED_CATEGORY] then
            return VARIANTS[PREFERRED_CATEGORY]
        end
    end

    -- 2) Единый проход по приоритету категорий (варианты Gun/Knife
    -- проверяются наравне с точным именем на каждом шаге)
    for _, CATEGORY in ipairs(CATEGORIES) do
        if BY_CATEGORY and BY_CATEGORY[CATEGORY] then
            return { { suffix = nil, entry = BY_CATEGORY[CATEGORY] } }
        end
        if VARIANTS and VARIANTS[CATEGORY] then
            return VARIANTS[CATEGORY]
        end
    end

    return nil
end

-- ==============================
-- ЧТЕНИЕ ТЕГА РЕДКОСТИ ИЗ GUI
-- ==============================
local function GET_PREFERRED_CATEGORY(ITEM_FRAME)
    local TAGS = ITEM_FRAME:FindFirstChild("Tags")
    if not TAGS then return nil end
    for _, TAG in ipairs(TAGS:GetChildren()) do
        if TAG:IsA("GuiObject") and TAG.Visible then
            local CATEGORY = TAG_TO_CATEGORY[string.lower(TAG.Name)]
            if CATEGORY and CATEGORY ~= "chromas" then
                return CATEGORY
            end
        end
    end
    return nil
end

local function GET_STABILITY_COLOR(STATUS)
    if STATUS and stabilityColors[STATUS] then
        return stabilityColors[STATUS]
    end
    return stabilityColors["Unknown"]
end

local function GET_STABILITY_ARROW(STATUS)
    if STATUS and stabilityArrows[STATUS] then
        return stabilityArrows[STATUS]
    end
    return stabilityArrows["Unknown"]
end

