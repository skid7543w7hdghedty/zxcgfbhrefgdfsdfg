-- UI
-- ==============================
local function CREATE_INFO_LABEL(PARENT)
    local infoLabel = Instance.new("TextLabel")
    infoLabel.Name = "InfoLabel"
    infoLabel.Size = UDim2.new(1, 0, 0.43, 0)
    infoLabel.Position = UDim2.new(0, 0, 0.15, 0)
    infoLabel.BackgroundTransparency = 0.5
    infoLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    infoLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    infoLabel.TextScaled = false
    infoLabel.TextWrapped = true
    infoLabel.Font = Enum.Font.GothamBold
    infoLabel.TextSize = 11
    infoLabel.RichText = true
    infoLabel.Parent = PARENT
    return infoLabel
end

local function BUILD_STABILITY_DISPLAY(STATUS, RANGE)
    if not STATUS then
        local color = stabilityColors["Unknown"]
        local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
        return string.format('<font color="rgb(%d,%d,%d)">Unknown ~</font>', r, g, b)
    end

    local color = GET_STABILITY_COLOR(STATUS)
    local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
    local arrow = GET_STABILITY_ARROW(STATUS)

    if STATUS == "Stable" then
        return string.format('<font color="rgb(%d,%d,%d)">%s %s</font>', r, g, b, STATUS, arrow)
    else
        local displayText = STATUS .. " " .. arrow
        if RANGE and RANGE ~= "" then
            displayText = displayText .. ", " .. RANGE
        end
        return string.format('<font color="rgb(%d,%d,%d)">%s</font>', r, g, b, displayText)
    end
end

local function CLEAR_ITEM_LABELS(ITEM_FRAME)
    local INFO_LABEL = ITEM_FRAME:FindFirstChild("InfoLabel")
    if INFO_LABEL then INFO_LABEL:Destroy() end
    local VALUE_LABEL = ITEM_FRAME:FindFirstChild("ValueLabel")
    if VALUE_LABEL then VALUE_LABEL:Destroy() end
    local DEMAND_LABEL = ITEM_FRAME:FindFirstChild("DemandLabel")
    if DEMAND_LABEL then DEMAND_LABEL:Destroy() end
    local STABILITY_LABEL = ITEM_FRAME:FindFirstChild("StabilityLabel")
    if STABILITY_LABEL then STABILITY_LABEL:Destroy() end
end

local function PARSE_ITEM_AMOUNT(AMOUNT_TEXT)
    if not AMOUNT_TEXT or AMOUNT_TEXT == "" then return 1 end
    local AMOUNT_NUM = tonumber(string.match(AMOUNT_TEXT, "^x(%d+)$"))
    if AMOUNT_NUM then return AMOUNT_NUM end
    return 1
end

local function GET_ITEM_UI_DATA(ITEM_FRAME)
    local ITEM_NAME_OBJ = ITEM_FRAME:FindFirstChild("ItemName")
    if not ITEM_NAME_OBJ then return nil end
    local ITEM_NAME_LBL = ITEM_NAME_OBJ:FindFirstChild("Label")
    if not ITEM_NAME_LBL or ITEM_NAME_LBL.Text == "" then return nil end
    local AMOUNT = 1
    local AMOUNT_CONT = ITEM_FRAME:FindFirstChild("Container")
    if AMOUNT_CONT then
        local AMOUNT_LBL = AMOUNT_CONT:FindFirstChild("Amount")
        if AMOUNT_LBL then AMOUNT = PARSE_ITEM_AMOUNT(AMOUNT_LBL.Text) end
    end
    local IS_CHROMA = false
    local TAGS = ITEM_FRAME:FindFirstChild("Tags")
    if TAGS then
        local CHROMA_TAG = TAGS:FindFirstChild("Chroma")
        if CHROMA_TAG then IS_CHROMA = CHROMA_TAG.Visible end
    end
    return ITEM_NAME_LBL.Text, AMOUNT, IS_CHROMA
end

-- Возвращает: nominal, minV, maxV (все уже умножены на количество)
local function UPDATE_ITEM_DISPLAY(ITEM_FRAME)
    if not ITEM_FRAME or not ITEM_FRAME:IsA("GuiObject") then return 0, 0, 0 end
    if not ITEM_FRAME.Visible then CLEAR_ITEM_LABELS(ITEM_FRAME); return 0, 0, 0 end
    local ITEM_NAME, AMOUNT, IS_CHROMA = GET_ITEM_UI_DATA(ITEM_FRAME)
    if not ITEM_NAME then CLEAR_ITEM_LABELS(ITEM_FRAME); return 0, 0, 0 end

    local PREFERRED_CATEGORY = GET_PREFERRED_CATEGORY(ITEM_FRAME)
    local ENTRIES = FIND_ITEM_ENTRIES(ITEM_NAME, IS_CHROMA, PREFERRED_CATEGORY)
    if not ENTRIES or #ENTRIES == 0 then CLEAR_ITEM_LABELS(ITEM_FRAME); return 0, 0, 0 end

    -- Common без числовой валюты (например "x1 T1 Common") ничего не стоят —
    -- не показываем для них оверлей и не считаем в трейде
    local HAS_REAL_VALUE = false
    for _, ITEM in ipairs(ENTRIES) do
        local CAT = ITEM.entry.category
        if ITEM.entry.valueNum or CAT ~= "commons" then
            HAS_REAL_VALUE = true
            break
        end
    end
    if not HAS_REAL_VALUE then CLEAR_ITEM_LABELS(ITEM_FRAME); return 0, 0, 0 end

    -- Агрегируем варианты (обычно 1 запись; для Gun/Knife может быть 2)
    local TOTAL_MIN, TOTAL_MAX, TOTAL_NOMINAL = nil, nil, nil
    local VALUE_PARTS = {}
    local FIRST_ENTRY = ENTRIES[1].entry

    for _, ITEM in ipairs(ENTRIES) do
        local DISPLAY, MIN_V, MAX_V, NOMINAL = RESOLVE_ENTRY_VALUE(ITEM.entry)
        if ITEM.suffix then
            table.insert(VALUE_PARTS, ITEM.suffix .. ": " .. DISPLAY)
        else
            table.insert(VALUE_PARTS, DISPLAY)
        end
        if NOMINAL then
            TOTAL_MIN = math.min(TOTAL_MIN or MIN_V, MIN_V)
            TOTAL_MAX = math.max(TOTAL_MAX or MAX_V, MAX_V)
            TOTAL_NOMINAL = math.max(TOTAL_NOMINAL or NOMINAL, NOMINAL)
        end
    end

    TOTAL_MIN = TOTAL_MIN or 0
    TOTAL_MAX = TOTAL_MAX or 0
    TOTAL_NOMINAL = TOTAL_NOMINAL or 0

    local INFO_LABEL = ITEM_FRAME:FindFirstChild("InfoLabel")
    if not INFO_LABEL then INFO_LABEL = CREATE_INFO_LABEL(ITEM_FRAME) end

    local VALUE_LINE = "Value: " .. table.concat(VALUE_PARTS, " / ")
    if AMOUNT > 1 and TOTAL_NOMINAL > 0 then
        VALUE_LINE = VALUE_LINE .. " (x" .. AMOUNT .. " = " .. (TOTAL_NOMINAL * AMOUNT) .. ")"
    end

    local DEMAND_LINE = "Demand: " .. (FIRST_ENTRY.demand or "N/A")
    if FIRST_ENTRY.rise ~= nil then
        DEMAND_LINE = DEMAND_LINE .. ", " .. FIRST_ENTRY.rise .. "%"
    end

    local STABILITY_LINE = BUILD_STABILITY_DISPLAY(FIRST_ENTRY.status, FIRST_ENTRY.rangeText)

    INFO_LABEL.Text = VALUE_LINE .. "\n" .. DEMAND_LINE .. "\n" .. STABILITY_LINE

    return TOTAL_NOMINAL * AMOUNT, TOTAL_MIN * AMOUNT, TOTAL_MAX * AMOUNT
end

local function HOOK_ITEM_FRAME(ITEM_FRAME, UPDATE_CALLBACK)
    if not ITEM_FRAME or ITEM_FRAME:GetAttribute("TradeHelperHooked") then return end
    ITEM_FRAME:SetAttribute("TradeHelperHooked", true)
    ITEM_FRAME:GetPropertyChangedSignal("Visible"):Connect(UPDATE_CALLBACK)
    local ITEM_NAME_OBJ = ITEM_FRAME:FindFirstChild("ItemName")
    if ITEM_NAME_OBJ then
        local ITEM_NAME_LBL = ITEM_NAME_OBJ:FindFirstChild("Label")
        if ITEM_NAME_LBL then ITEM_NAME_LBL:GetPropertyChangedSignal("Text"):Connect(UPDATE_CALLBACK) end
    end
    local AMOUNT_CONT = ITEM_FRAME:FindFirstChild("Container")
    if AMOUNT_CONT then
        local AMOUNT_LBL = AMOUNT_CONT:FindFirstChild("Amount")
        if AMOUNT_LBL then AMOUNT_LBL:GetPropertyChangedSignal("Text"):Connect(UPDATE_CALLBACK) end
    end
    local TAGS = ITEM_FRAME:FindFirstChild("Tags")
    if TAGS then
        for _, TAG in ipairs(TAGS:GetChildren()) do
            if TAG:IsA("GuiObject") then
                TAG:GetPropertyChangedSignal("Visible"):Connect(UPDATE_CALLBACK)
            end
        end
    end
end

local function SETUP_TRADE_GUI(TG)
    local CONT = TG:WaitForChild("Container", 5)
    if not CONT then return end
    local TR = CONT:WaitForChild("Trade", 5)
    if not TR then return end
    local YO = TR:WaitForChild("YourOffer", 5)
    if not YO then return end
    local YOC = YO:WaitForChild("Container", 5)
    if not YOC then return end
    local YOT = YO:WaitForChild("Title", 5)
    if not YOT then return end
    local TO = TR:WaitForChild("TheirOffer", 5)
    if not TO then return end
    local TOC = TO:WaitForChild("Container", 5)
    if not TOC then return end
    local TOT = TO:WaitForChild("Title", 5)
    if not TOT then return end

    -- Автомасштабирование заголовков: длинный текст (Min/Max профит,
    -- диапазоны) уменьшается, чтобы всегда помещаться в рамки
    for _, TITLE in ipairs({ YOT, TOT }) do
        if TITLE:IsA("TextLabel") then
            TITLE.TextScaled = true
            TITLE.TextWrapped = true
            local CONSTRAINT = TITLE:FindFirstChild("TradeHelperTextConstraint")
            if not CONSTRAINT then
                CONSTRAINT = Instance.new("UITextSizeConstraint")
                CONSTRAINT.Name = "TradeHelperTextConstraint"
                CONSTRAINT.MinTextSize = 12
                CONSTRAINT.MaxTextSize = 22
                CONSTRAINT.Parent = TITLE
            end
        end
    end

    local function SUM_OFFER(CONTAINER)
        local TOTAL, TOTAL_MIN, TOTAL_MAX = 0, 0, 0
        for I = 1, 4 do
            local NEW_ITEM = CONTAINER:FindFirstChild("NewItem" .. I)
            if NEW_ITEM then
                local V, MIN_V, MAX_V = UPDATE_ITEM_DISPLAY(NEW_ITEM)
                TOTAL = TOTAL + V
                TOTAL_MIN = TOTAL_MIN + MIN_V
                TOTAL_MAX = TOTAL_MAX + MAX_V
            end
        end
        return TOTAL, TOTAL_MIN, TOTAL_MAX
    end

    local function UPDATE_OFFER_VALUES()
        local YOUR_TOTAL, YOUR_MIN, YOUR_MAX = SUM_OFFER(YOC)
        local THEIR_TOTAL, THEIR_MIN, THEIR_MAX = SUM_OFFER(TOC)

        -- Другой игрок: сколько он даёт сейчас, в скобках — минимум и максимум
        -- (скобки появляются только если есть предметы со статусом кроме Stable:
        -- Overpaid For, Underpaid For, Fluctuating и т.д.)
        local THEIR_TEXT = "Values: " .. THEIR_TOTAL
        if THEIR_MIN ~= THEIR_MAX then
            THEIR_TEXT = THEIR_TEXT .. " (" .. THEIR_MIN .. "-" .. THEIR_MAX .. ")"
        end
        TOT.Text = THEIR_TEXT

        -- Вы: сколько валют вы отдаёте, затем профит и его разброс
        local YOUR_TEXT = "Values: " .. YOUR_TOTAL
        if THEIR_TOTAL > 0 then
            local PROFIT = THEIR_TOTAL - YOUR_TOTAL
            YOUR_TEXT = YOUR_TEXT .. " | Profit: " .. PROFIT
            -- Минимальный профит: их минимум минус ваш максимум
            -- (худший сценарий: их скины по нижней границе, ваши — по верхней)
            local MIN_PROFIT = THEIR_MIN - YOUR_MAX
            -- Максимальный профит: их максимум минус ваш минимум
            local MAX_PROFIT = THEIR_MAX - YOUR_MIN
            if MIN_PROFIT ~= MAX_PROFIT then
                YOUR_TEXT = YOUR_TEXT .. " (" .. MIN_PROFIT .. "-" .. MAX_PROFIT .. ")"
            end
        end
        YOT.Text = YOUR_TEXT
    end

    UPDATE_OFFER_VALUES()
    for I = 1, 4 do
        local NEW_ITEM = YOC:FindFirstChild("NewItem" .. I)
        if NEW_ITEM then HOOK_ITEM_FRAME(NEW_ITEM, UPDATE_OFFER_VALUES) end
    end
    for I = 1, 4 do
        local NEW_ITEM = TOC:FindFirstChild("NewItem" .. I)
        if NEW_ITEM then HOOK_ITEM_FRAME(NEW_ITEM, UPDATE_OFFER_VALUES) end
    end
end

-- Слоты офферов (YourOffer/TheirOffer) обрабатываются отдельно
-- в SETUP_TRADE_GUI, поэтому их пропускаем. Всё остальное — включая
-- панель выбора своих скинов ВНУТРИ трейд-окна, свой инвентарь и
-- профили других игроков — хукаем здесь.
local function IS_TRADE_OBJECT(OBJ)
    local CURRENT = OBJ
    local IN_TRADE_GUI = false
    local IN_OFFER = false
    while CURRENT and CURRENT ~= PG do
        local LOWER_NAME = string.lower(CURRENT.Name)
        if string.find(LOWER_NAME, "tradegui", 1, true) then
            IN_TRADE_GUI = true
        end
        if LOWER_NAME == "youroffer" or LOWER_NAME == "theiroffer" then
            IN_OFFER = true
        end
        CURRENT = CURRENT.Parent
    end
    -- Пропускаем только слоты офферов внутри трейд-окна
    return IN_TRADE_GUI and IN_OFFER
end

local function TRY_SETUP_INVENTORY_ITEM(OBJ)
    if not OBJ or not OBJ:IsA("GuiObject") then return end
    -- Фрейм предмета определяем по структуре: ItemName -> Label
    local ITEM_NAME_OBJ = OBJ:FindFirstChild("ItemName")
    if not ITEM_NAME_OBJ then return end
    local ITEM_NAME_LBL = ITEM_NAME_OBJ:FindFirstChild("Label")
    if not ITEM_NAME_LBL then return end
    if IS_TRADE_OBJECT(OBJ) then return end
    local function UPDATE_THIS_ITEM() UPDATE_ITEM_DISPLAY(OBJ) end
    HOOK_ITEM_FRAME(OBJ, UPDATE_THIS_ITEM)
    UPDATE_THIS_ITEM()
end

local function SETUP_INVENTORY_GUI()
    for _, OBJ in ipairs(PG:GetDescendants()) do
        TRY_SETUP_INVENTORY_ITEM(OBJ)
    end
    PG.DescendantAdded:Connect(function(OBJ)
        -- В профилях игроков ItemName/Label создаются ПОСЛЕ самого фрейма,
        -- поэтому пробуем и сам объект, и его предков с небольшой задержкой
        task.defer(function()
            TRY_SETUP_INVENTORY_ITEM(OBJ)
            if OBJ.Name == "Label" and OBJ.Parent and OBJ.Parent.Name == "ItemName" then
                TRY_SETUP_INVENTORY_ITEM(OBJ.Parent.Parent)
            elseif OBJ.Name == "ItemName" then
                TRY_SETUP_INVENTORY_ITEM(OBJ.Parent)
            end
        end)
    end)
end

